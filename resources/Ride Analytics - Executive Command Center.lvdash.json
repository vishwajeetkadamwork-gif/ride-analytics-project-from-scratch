{
  "datasets": [
    {
      "name": "9e17d598",
      "displayName": "Live KPIs",
      "queryLines": [
        "select \n",
        "total_revenue_inr,\n",
        "cancellation_rate_pct,\n",
        "active_drivers,\n",
        "avg_fare_inr,\n",
        "cast(round(total_rides*(100 - cancellation_rate_pct)/100,0)as bigint) as completed_rides\n",
        "from workspace.realtime.gold_live_kpis"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "9fe618f9",
      "displayName": "Revenue Per Minute",
      "queryLines": [
        "select\n",
        "revenue_inr,\n",
        "completed_rides,\n",
        "minute_bucket\n",
        "\n",
        "from workspace.realtime.gold_revenue_per_minute\n",
        "order by minute_bucket"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "0517af2b",
      "displayName": "Ride Status Summary With Total Counts",
      "queryLines": [
        "select status,\n",
        "cast(ride_count as bigint) as ride_count \n",
        "from workspace.realtime.gold_ride_status_breakdown order by ride_count desc"
      ]
    },
    {
      "name": "2eda1bba",
      "displayName": "City Performance",
      "queryLines": [
        "select city,round(revenue_inr,0) as revenue_inr\n",
        " from workspace.realtime.gold_rides_by_city order by revenue_inr desc"
      ]
    },
    {
      "name": "f9bd2be2",
      "displayName": "Top Revenue Zones",
      "queryLines": [
        "select \n",
        "zone_id,\n",
        "city,\n",
        "round(total_revenue_inr,0) as total_revenue_inr,\n",
        "cast(completed_rides as bigint) as completed_rides,\n",
        "round(avg_fare_inr,0) as avg_fare_inr\n",
        " from workspace.realtime.gold_top_zones order by total_revenue_inr desc limit 10"
      ]
    },
    {
      "name": "b03901b5",
      "displayName": "Cancellation Reasons",
      "queryLines": [
        "        SELECT city, COALESCE(NULLIF(cancellation_reason,''), status) AS reason, CAST(SUM(cancellation_count) AS BIGINT) \n",
        "        AS cancellation_count FROM workspace.realtime.gold_cancellation_analysis GROUP BY city, COALESCE(NULLIF(cancellation_reason,''), status) ORDER BY cancellation_count DESC\n"
      ]
    },
    {
      "name": "a66a22c3",
      "displayName": "Pickup Demand",
      "queryLines": [
        "        SELECT city, pickup_area, zone_id, CAST(SUM(total_rides) AS BIGINT) AS total_rides, CAST(SUM(cancelled_rides) AS BIGINT) AS cancelled_rides, ROUND(SUM(cancelled_rides) * 100.0 / NULLIF(SUM(total_rides), 0), 1) AS cancel_rate_pct FROM workspace.realtime.gold_pickup_demand GROUP BY city, pickup_area, zone_id ORDER BY total_rides DESC\n"
      ]
    }
  ],
